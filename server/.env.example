# Copy to .env and fill in values.

PORT=3001

# Comma-separated origins allowed for CORS (browser). Vite default:
CORS_ORIGIN=http://localhost:5173

# Spotify — https://developer.spotify.com/dashboard
# Client Credentials flow (no user login; public catalog only).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# SoundCloud — https://developers.soundcloud.com/
# OAuth 2.1 client credentials (server-side).
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# PKCE + authorization code: must match the redirect URI in your SoundCloud app exactly.
# Default if unset: http://localhost:PORT/api/soundcloud/auth/callback
# Flow: open GET /api/soundcloud/auth/start → then SoundCloud sends user back here with ?code.
SOUNDCLOUD_REDIRECT_URI=

# Optional: where to store OAuth user tokens (default: server/.soundcloud-user-tokens.json).
# On Fly.io, point this at a file on a mounted volume so refresh survives deploys.
# SOUNDCLOUD_USER_TOKEN_FILE=/data/soundcloud-user-tokens.json

# Optional: override user access token. Normally omitted — after one visit to
# /api/soundcloud/auth/start, tokens live on disk (see above). Use if you cannot persist a file.
SOUNDCLOUD_USER_ACCESS_TOKEN=
